# OpenRouter API configuration
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# LLM settings
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60

# Vosk STT settings
VOSK_MODEL_PATH=models/model-small-ru
VOSK_SAMPLE_RATE=16000
VOSK_CHUNK_SIZE=1024
VOSK_SILENCE_THRESHOLD=600
VOSK_SILENCE_TIMEOUT=0.8
VOSK_RECORD_TIMEOUT=10

# edge-tts settings
TTS_VOICE=ru-RU-SvetlanaNeural
TTS_CACHE_ENABLED=true
TTS_CACHE_DIR=/tmp/voice-assistant-tts

# General application settings
DEBUG=false
LOG_LEVEL=INFO
TRIGGER_WORD=jarvis
AUDIO_DEVICE_INDEX=null